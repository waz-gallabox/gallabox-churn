# Gallabox Churn — environment credentials template
# Copy this file to .env and fill in the real values.
# Get the actual values from the team's shared secrets (1Password / Notion).
# NEVER commit .env — it is in .gitignore.

# ── PocketBase ────────────────────────────────────────────
PB_BASE=http://127.0.0.1:8090
PB_EMAIL=admin@gallabox.com        # must match PocketBase admin account email
PB_PASSWORD=

# ── Frontend (Next.js) ────────────────────────────────────
# LOCAL: keep as 127.0.0.1
# SERVER: change to your server's public IP or domain before deploying
NEXT_PUBLIC_PB_BASE=http://127.0.0.1:8090

# ── ClickHouse (Gallabox analytics cluster) ───────────────
CH_HOST=https://<cluster-id>.ap-southeast-1.aws.clickhouse.cloud:8443
CH_USER=default
CH_PASS=

# ── Chargebee ─────────────────────────────────────────────
CB_SITE=gallaboxglobal.chargebee.com
CB_KEY=

# ── Zoho (CRM + Desk) ─────────────────────────────────────
# OAuth tokens — auto-refreshed by zoho_auth.py
ZOHO_DESK_ORG_ID=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── MongoDB (Gallabox Prod — read-only replica) ────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gbProdDB?authSource=admin&replicaSet=atlas-xnlxo6-shard-0&readPreference=secondary&ssl=true&serverSelectionTimeoutMS=10000&connectTimeoutMS=10000
